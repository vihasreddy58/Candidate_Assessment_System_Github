{
  "name": "github-hiring-analysis-system",
  "version": "1.0.0",
  "description": "Complete GitHub-Based Hiring Analysis System",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "client": "cd frontend && npm run dev",
    "server": "nodemon backend/server.js",
    "install-all": "npm install && cd frontend && npm install",
    "dev-all": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "github",
    "hiring",
    "resume",
    "analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mammoth": "^1.6.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "natural": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^3.1.4",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
